generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Object {
  id            String   @id @default(cuid())
  name          String
  size          Int
  storagePath   String
  archiveStatus String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  deletedAt     DateTime?
}

model Job {
  id           String   @id @default(cuid())
  objectId     String
  type         String   
  status       String   @default("QUEUED")
  startByte    Int?
  endByte      Int?
  errorMessage String?
  createdAt    DateTime @default(now())
  completedAt  DateTime?
}

model AuditLog {
  id        String   @id @default(cuid())
  objectId  String
  action    String
  timestamp DateTime @default(now())
}